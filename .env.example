# Postgres connection string.
# Local Docker (see docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skill_marketplace"
# Neon (production): postgresql://<user>:<pass>@<host>/<db>?sslmode=require

# Better Auth
BETTER_AUTH_SECRET="dev-secret-change-me-in-production-please-32chars"
BETTER_AUTH_URL="http://localhost:3000"

# Anthropic (LLM injection classifier). Optional in dev — the scanner's LLM
# layer is best-effort and degrades gracefully when this is unset.
ANTHROPIC_API_KEY=""
